{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Issuer Disclosure Subscriptions V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "subscriptions"],
  "properties": {
    "manifest_version": {"const": 1},
    "subscriptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["subscription_id", "asset_id", "market", "symbol"],
        "properties": {
          "subscription_id": {"type": "string", "minLength": 1},
          "asset_id": {"type": "string", "minLength": 1},
          "market": {"const": "US"},
          "symbol": {"type": "string", "minLength": 1},
          "issuer_id": {"type": "string", "pattern": "^[0-9]{1,10}$"},
          "forms": {
            "type": "array", "minItems": 1, "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "enabled": {"type": "boolean", "default": true}
        }
      }
    }
  }
}
