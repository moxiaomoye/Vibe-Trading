{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibe-trading.local/schemas/thesis-initialization-v3.json",
  "title": "AI Investment Researcher Thesis Initialization Manifest V3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "thesis_id",
    "information_cutoff",
    "initialized_at",
    "evidence",
    "associations",
    "proposal"
  ],
  "properties": {
    "manifest_version": {"const": 3},
    "thesis_id": {"type": "string", "minLength": 1},
    "information_cutoff": {"type": "string", "format": "date-time"},
    "initialized_at": {"type": "string", "format": "date-time"},
    "evidence": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "provider",
          "source_locator",
          "title",
          "summary",
          "published_at",
          "available_at",
          "observed_at"
        ],
        "properties": {
          "evidence_id": {"type": "string", "minLength": 1},
          "provider": {"type": "string", "minLength": 1},
          "source_locator": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "summary": {"type": "string", "minLength": 1},
          "published_at": {"type": "string", "format": "date-time"},
          "available_at": {"type": "string", "format": "date-time"},
          "observed_at": {"type": "string", "format": "date-time"},
          "content_hash": {"type": "string"},
          "quality_warnings": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "associations": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["association_id", "evidence_id", "direction", "assessed_at", "assessor", "rationale"],
        "properties": {
          "association_id": {"type": "string", "minLength": 1},
          "evidence_id": {"type": "string", "minLength": 1},
          "direction": {"enum": ["supporting", "counter", "neutral"]},
          "assessed_at": {"type": "string", "format": "date-time"},
          "assessor": {"type": "string", "minLength": 1},
          "rationale": {"type": "string", "minLength": 1}
        }
      }
    },
    "proposal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "core_claim",
        "confidence",
        "supporting_evidence_ids",
        "counter_evidence_ids",
        "catalysts",
        "kill_criteria",
        "change_summary",
        "next_review_at",
        "initializer",
        "approval_reference",
        "evidence_set_review_id"
      ],
      "properties": {
        "status": {"enum": ["active", "weakening"]},
        "core_claim": {"type": "string", "minLength": 1},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "supporting_evidence_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "counter_evidence_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "catalysts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "kill_criteria": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "change_summary": {"type": "string", "minLength": 1},
        "next_review_at": {"type": "string", "format": "date-time"},
        "initializer": {"type": "string", "minLength": 1},
        "approval_reference": {"type": "string", "minLength": 1},
        "evidence_set_review_id": {"type": "string", "minLength": 1}
      }
    }
  }
}
